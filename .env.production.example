NODE_ENV=production
PORT=3003
PUBLIC_URL=https://mockup.yourdomain.com

# Paths (container defaults, usually no need to change)
DB_PATH=/app/data/data.db
UPLOADS_DIR=/app/uploads
OUTPUT_DIR=/app/output

# Required in production: protects /api/settings
API_SECRET=

# API Tokens
PRINTFUL_TOKEN=
PRINTIFY_TOKEN=
PRINTIFY_SHOP_ID=
